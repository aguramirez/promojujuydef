generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id         String      @id @default(uuid())
  name       String      @unique
  promotions Promotion[]
}

model Promotion {
  id          String          @id @default(uuid())
  storeName   String
  imageUrl    String
  description String
  startDate   DateTime
  endDate     DateTime
  ctaUrl      String
  status      PromotionStatus @default(NORMAL)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  categoryId  String?
  mapsUrl     String?
  published   Boolean         @default(false)
  title       String?
  dias        String[]        @default([])
  category    Category?       @relation(fields: [categoryId], references: [id])

  @@index([startDate, endDate])
}

model Event {
  id          String          @id @default(uuid())
  storeName   String
  title       String?
  imageUrl    String
  description String
  date        DateTime
  ctaUrl      String
  mapsUrl     String?
  status      PromotionStatus @default(NORMAL)
  published   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Admin {
  id       String @id @default(uuid())
  username String @unique
  password String
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  whatsapp  String
  createdAt DateTime @default(now())
}

enum PromotionStatus {
  ESTRELLA
  IMPORTANTE
  NORMAL
  ULTIMO
}
